# =====================================================================
# RoomBook — Environment Variables
# Copy this file to .env and fill in the values
# =====================================================================

# ─── App ─────────────────────────────────────────────────────────────
ENVIRONMENT=production

# REQUIRED in production — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# ─── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_USER=roombook
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=roombook

# ─── Email (SendGrid) ───────────────────────────────────────────────
# Leave empty to disable email (logs to console instead)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated allowed origins (add your production domain)
# CORS_ORIGINS=https://roombook.yourdomain.com,https://yourdomain.com
CORS_ORIGINS=

# ─── SSL/Domain ──────────────────────────────────────────────────
# Your production domain (used for Let's Encrypt certificate)
# DOMAIN=roombook.yourdomain.com
# ─── Frontend ────────────────────────────────────────────────────────
# Internal Docker network URL for SSR to reach backend
NEXT_PUBLIC_API_URL=http://backend:8000
